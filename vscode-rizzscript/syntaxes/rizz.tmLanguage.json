{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "RizzScript",
    "patterns": [
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#comments"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#classes"
        },
        {
            "include": "#literals"
        }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.rizz",
                    "match": "\\b(yo fam|peace out|ghost|sus check|or nah|loop the vibe|grind|drop|vibe check)\\b"
                },
                {
                    "name": "keyword.control.flow.rizz",
                    "match": "\\b(from|to)\\b"
                },
                {
                    "name": "storage.type.rizz",
                    "match": "\\b(vibe|lock in|aura|squad|cook|fresh)\\b"
                },
                {
                    "name": "support.function.rizz",
                    "match": "\\b(spill|slay|len|str|num|push|pop)\\b"
                }
            ]
        },
        "literals": {
            "patterns": [
                {
                    "name": "constant.language.rizz",
                    "match": "\\b(bet|cap|mid)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.rizz",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.rizz",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.rizz",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.rizz",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.rizz",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.rizz",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.rizz",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.rizz",
                    "match": "(==|!=|<=|>=|<|>|&&|\\|\\||!|\\+|-|\\*|/|%|=)"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()",
                    "name": "entity.name.function.rizz"
                }
            ]
        },
        "classes": {
            "patterns": [
                {
                    "name": "entity.name.class.rizz",
                    "match": "(?<=\\baura\\s+)[a-zA-Z_]\\w*"
                }
            ]
        }
    },
    "scopeName": "source.rizz"
}